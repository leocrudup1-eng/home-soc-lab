<!-- Custom Wazuh Detection Rules -->
<!-- EdgeRouter X / Ubiquiti Events -->
<!-- Location: /var/ossec/etc/rules/local_rules.xml -->

<group name="ubiquiti,edgerouter,">

  <!-- EdgeRouter firewall block event -->
  <rule id="100001" level="5">
    <program_name>kernel</program_name>
    <match>UBNT_FW</match>
    <description>EdgeRouter firewall event</description>
    <group>firewall,</group>
  </rule>

  <!-- SSH brute force / failed login -->
  <rule id="100002" level="10">
    <program_name>sshd</program_name>
    <match>Failed password</match>
    <description>EdgeRouter SSH failed login attempt</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- New DHCP lease (new device on network) -->
  <rule id="100003" level="5">
    <program_name>dhcpd</program_name>
    <match>DHCPACK</match>
    <description>EdgeRouter new DHCP lease assigned</description>
    <group>dhcp,</group>
  </rule>

  <!-- Successful SSH login to router -->
  <rule id="100004" level="12">
    <program_name>sshd</program_name>
    <match>Accepted password|Accepted publickey</match>
    <description>EdgeRouter successful SSH login</description>
    <group>authentication_success,</group>
  </rule>

</group>
